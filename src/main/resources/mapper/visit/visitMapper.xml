<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ucamp.gyeongjuma_be.visit.repository.VisitRepository">
    <select id="existsByMemberIdAndPlaceId" resultType="boolean">
        SELECT EXISTS(
            SELECT 1
            FROM visit
            WHERE member_id = #{memberId}
              AND place_id = #{placeId}
        )
    </select>

    <insert id="save" useGeneratedKeys="true" keyProperty="visitId">
        INSERT INTO visit (member_id, place_id)
        VALUES (#{memberId}, #{placeId})
    </insert>
</mapper>
